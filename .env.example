# Provider credentials.
# Prefer `magi setup`, which writes these to the user config file.
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional OpenAI configuration.
OPENAI_API_BASE=
OPENAI_ORGANIZATION=
OPENAI_MODEL=gpt-5-mini
MAGI_OPENAI_FAST_MODEL=gpt-5-mini
MAGI_OPENAI_STRONG_MODEL=gpt-5.2
MAGI_OPENAI_HIGH_STAKES_MODEL=gpt-5.2
MAGI_ENABLE_MODEL_ROUTING=true
MAGI_ENABLE_LIVE_PERSONAS=false
MAGI_ENABLE_RESPONDER_LLM=false
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional Gemini configuration.
GEMINI_MODEL=gemini-2.5-flash-lite
GOOGLE_PROJECT=
GOOGLE_LOCATION=
GOOGLE_USE_VERTEX=false

# Retrieval / runtime controls.
MAGI_FORCE_DSPY_STUB=0
MAGI_FORCE_HASH_EMBEDDER=0
MAGI_ALLOW_OFFLINE=0
MAGI_PROVIDER_MAX_RETRIES=3
MAGI_PROVIDER_RETRY_INITIAL_DELAY=1.0
MAGI_PROVIDER_REQUESTS_PER_MINUTE=0
MAGI_APPROVE_MIN_CITATION_HIT_RATE=1.0
MAGI_APPROVE_MIN_ANSWER_SUPPORT_SCORE=0.2
MAGI_REQUIRE_HUMAN_REVIEW_FOR_APPROVALS=true
MAGI_DECISION_TRACE_DIR=

# Optional PostgreSQL + pgvector backend.
DATABASE_URL=
